generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  chofer
  almacenista
  supervisor
  manager
  rrhh
  admin
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

enum Direction {
  inbound
  outbound
}

enum MessageType {
  text
  audio
  document
  system
}

enum RouteStatus {
  started
  closed
}

enum Severity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  closed
}

enum FileKind {
  audio
  payroll_pdf
  evidence
  document
}

enum NotificationChannel {
  telegram
  email
}

enum ReminderType {
  personal
  system
}

enum ReminderStatus {
  pending
  delivered
  cancelled
}

enum WorkType {
  route
  order
  appointment
  visit
  task
}

enum WorkItemStatus {
  draft
  assigned
  acknowledged
  completed
  cancelled
}

enum WorkAssignmentStatus {
  active
  reassigned
  completed
  cancelled
}

enum WorkItemEventType {
  created
  assigned
  reassigned
  updated
  completed
  cancelled
  note_added
  note_promoted
}

enum OperationalNoteType {
  work_note
  person_preference
  account_rule
  provisional_observation
}

model Tenant {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  status         String             @default("active")
  timezone       String             @default("America/Santo_Domingo")
  createdAt      DateTime           @default(now())
  users          User[]
  sessions       ConversationSession[]
  routes         DriverRoute[]
  pickings       WarehousePicking[]
  loadings       TruckLoading[]
  incidents      Incident[]
  payrolls       PayrollDocument[]
  files          StoredFile[]
  alertTargets   TenantAlertTarget[]
  auditLogs      AuditLog[]
  integrationApiKeys IntegrationApiKey[]
  integrationRequests IntegrationRequest[]
  settings       TenantSettings?
  documents      TenantDocument[]
  reminders      Reminder[]
  commercialAccounts CommercialAccount[]
  channelEndpoints ChannelEndpoint[]
  contactPersons ContactPerson[]
  workItems       WorkItem[]
  workAssignments WorkAssignment[]
  operationalNotes OperationalNote[]
  workItemEvents  WorkItemEvent[]
}

model User {
  id              String               @id @default(cuid())
  tenantId        String
  employeeCode    String
  pinHash         String
  mustChangePin   Boolean              @default(false)
  pinUpdatedAt    DateTime?
  fullName        String
  email           String?
  phone           String?
  status          UserStatus           @default(ACTIVE)
  createdAt       DateTime             @default(now())
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  roles           UserRoleAssignment[]
  telegramLinks   TelegramLink[]
  webSessions     WebSession[]
  conversationSessions ConversationSession[]
  conversationMessages ConversationMessage[]
  driverRoutes    DriverRoute[]
  warehousePickings WarehousePicking[]
  truckLoadings   TruckLoading[]
  incidents       Incident[]
  payrolls        PayrollDocument[]    @relation("PayrollEmployee")
  uploadedPayrolls PayrollDocument[]   @relation("PayrollUploader")
  files           StoredFile[]
  auditLogs       AuditLog[]
  uploadedDocuments TenantDocument[]
  reminders       Reminder[]
  channelEndpoints ChannelEndpoint[]
  assignedWorkItems WorkItem[]           @relation("AssignedWorkItems")
  createdWorkItems  WorkItem[]           @relation("CreatedWorkItems")
  workAssignments   WorkAssignment[]     @relation("AssignedUserAssignments")
  assignmentActions WorkAssignment[]     @relation("AssignmentActor")
  operationalNotes  OperationalNote[]    @relation("OperationalNoteAuthor")
  noteDecisions     OperationalNote[]    @relation("OperationalNoteDecider")
  workItemEvents    WorkItemEvent[]      @relation("WorkItemEventActor")

  @@unique([tenantId, employeeCode])
  @@index([tenantId, createdAt])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId, role])
}

model TelegramLink {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  telegramUserId String
  telegramChatId String
  linkedAt       DateTime  @default(now())
  revokedAt      DateTime?
  lastSeenAt     DateTime?
  user           User      @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@unique([tenantId, telegramUserId])
}

model WebSession {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
}

model ConversationSession {
  id            String              @id @default(cuid())
  tenantId      String
  userId        String?
  accountId     String?
  contactPersonId String?
  channelEndpointId String?
  channel       String
  status        ConversationStatus  @default(ACTIVE)
  activeFlow    String?
  currentStep   String?
  contextJson   Json?
  updatedAt     DateTime            @updatedAt
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  user          User?               @relation(fields: [userId], references: [id])
  account       CommercialAccount?  @relation(fields: [accountId], references: [id])
  contactPerson ContactPerson?      @relation(fields: [contactPersonId], references: [id])
  channelEndpoint ChannelEndpoint?  @relation(fields: [channelEndpointId], references: [id])
  messages      ConversationMessage[]
  driverRoutes  DriverRoute[]
  pickings      WarehousePicking[]
  loadings      TruckLoading[]

  @@index([tenantId, userId, status])
  @@index([tenantId, accountId, status])
  @@index([tenantId, contactPersonId, status])
  @@index([tenantId, channelEndpointId, status])
}

model ConversationMessage {
  id               String   @id @default(cuid())
  tenantId         String
  sessionId        String
  userId           String?
  accountId        String?
  contactPersonId  String?
  channelEndpointId String?
  direction        Direction
  messageType      MessageType
  rawText          String?
  transcriptText   String?
  intent           String?
  intentConfidence Float?
  entitiesJson     Json?
  createdAt        DateTime @default(now())
  session          ConversationSession @relation(fields: [sessionId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  account          CommercialAccount? @relation(fields: [accountId], references: [id])
  contactPerson    ContactPerson? @relation(fields: [contactPersonId], references: [id])
  channelEndpoint  ChannelEndpoint? @relation(fields: [channelEndpointId], references: [id])
  sourcedNotes     OperationalNote[] @relation("OperationalNoteSourceMessage")

  @@index([tenantId, createdAt])
  @@index([tenantId, accountId, createdAt])
  @@index([tenantId, contactPersonId, createdAt])
}

model DriverRoute {
  id              String   @id @default(cuid())
  tenantId        String
  driverUserId    String
  vehicleLabel    String
  status          RouteStatus
  startOdometer   Float
  endOdometer     Float?
  startedAt       DateTime
  closedAt        DateTime?
  sourceSessionId String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  driver          User     @relation(fields: [driverUserId], references: [id])
  sourceSession   ConversationSession? @relation(fields: [sourceSessionId], references: [id])
  invoices        DriverInvoice[]
  incidents       Incident[]

  @@index([tenantId, startedAt])
}

model DriverInvoice {
  id            String   @id @default(cuid())
  tenantId      String
  routeId       String
  invoiceNumber String
  createdAt     DateTime @default(now())
  route         DriverRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model WarehousePicking {
  id              String   @id @default(cuid())
  tenantId        String
  workerUserId    String
  orderRef        String
  routeRef        String?
  vehicleLabel    String?
  pickedAt        DateTime
  notes           String?
  sourceSessionId String?
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  worker          User     @relation(fields: [workerUserId], references: [id])
  sourceSession   ConversationSession? @relation(fields: [sourceSessionId], references: [id])

  @@index([tenantId, pickedAt])
}

model TruckLoading {
  id            String   @id @default(cuid())
  tenantId      String
  workerUserId  String
  vehicleLabel  String
  boxCount      Int?
  weightKg      Float?
  loadedAt      DateTime
  notes         String?
  sourceSessionId String?
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  worker        User     @relation(fields: [workerUserId], references: [id])
  sourceSession ConversationSession? @relation(fields: [sourceSessionId], references: [id])

  @@index([tenantId, loadedAt])
}

model Incident {
  id               String         @id @default(cuid())
  tenantId         String
  reportedByUserId String
  sourceType       String
  relatedRouteId   String?
  severity         Severity
  incidentType     String
  title            String
  description      String
  status           IncidentStatus @default(open)
  detectedByAi     Boolean        @default(false)
  createdAt        DateTime       @default(now())
  closedAt         DateTime?
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  reportedBy       User           @relation(fields: [reportedByUserId], references: [id])
  relatedRoute     DriverRoute?   @relation(fields: [relatedRouteId], references: [id])
  notifications    IncidentNotification[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, severity])
}

model IncidentNotification {
  id         String              @id @default(cuid())
  tenantId   String
  incidentId String
  channel    NotificationChannel
  recipient  String
  status     String              @default("pending")
  sentAt     DateTime?
  errorText  String?
  incident   Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt])
}

model PayrollDocument {
  id               String   @id @default(cuid())
  tenantId         String
  employeeUserId   String
  periodYear       Int
  periodMonth      Int
  fileId           String
  uploadedByUserId String
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  employee         User     @relation("PayrollEmployee", fields: [employeeUserId], references: [id])
  uploadedBy       User     @relation("PayrollUploader", fields: [uploadedByUserId], references: [id])
  file             StoredFile @relation(fields: [fileId], references: [id])

  @@unique([tenantId, employeeUserId, periodYear, periodMonth])
  @@index([tenantId, createdAt])
}

model StoredFile {
  id              String   @id @default(cuid())
  tenantId        String
  storageKey      String
  originalName    String
  mimeType        String
  sizeBytes       Int
  fileKind        FileKind
  createdByUserId String?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])
  payrolls        PayrollDocument[]
  documents       TenantDocument[]

  @@index([tenantId, createdAt])
}

model CommercialAccount {
  id              String   @id @default(cuid())
  tenantId        String
  externalRef     String?
  name            String
  commercialMemory Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoints       ChannelEndpoint[]
  people          ContactPerson[]
  sessions        ConversationSession[]
  messages        ConversationMessage[]
  documents       TenantDocument[]
  workItems       WorkItem[]
  operationalNotes OperationalNote[]

  @@index([tenantId, name])
  @@unique([tenantId, externalRef])
}

model ContactPerson {
  id                String   @id @default(cuid())
  tenantId          String
  accountId         String
  fullName          String
  alias             String?
  personalMemory    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account           CommercialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  currentEndpoints  ChannelEndpoint[] @relation("CurrentEndpointPerson")
  sessions          ConversationSession[]
  messages          ConversationMessage[]
  workItems         WorkItem[]
  operationalNotes  OperationalNote[]

  @@index([tenantId, accountId, fullName])
}

model ChannelEndpoint {
  id               String   @id @default(cuid())
  tenantId         String
  channel          String
  provider         String
  endpointExternalId String
  label            String?
  accountId        String?
  userId           String?
  currentPersonId  String?
  metadataJson     Json?
  linkedAt         DateTime @default(now())
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account          CommercialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  currentPerson    ContactPerson? @relation("CurrentEndpointPerson", fields: [currentPersonId], references: [id], onDelete: SetNull)
  sessions         ConversationSession[]
  messages         ConversationMessage[]
  documents        TenantDocument[]

  @@unique([tenantId, channel, provider, endpointExternalId])
  @@index([tenantId, accountId, revokedAt])
  @@index([tenantId, userId, revokedAt])
}

model TenantSettings {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  companyName            String?
  businessProfile        String   @default("logistics")
  companyDescription     String?
  companyTimezone        String?
  operationalHours       String?
  responsibleName        String?
  responsibleEmail       String?
  telegramEnabled        Boolean  @default(true)
  telegramBotToken       String?
  emailProvider          String?
  outboundEmailFrom      String?
  smtpHost               String?
  smtpPort               Int?
  smtpUser               String?
  smtpPassword           String?
  aiProvider             String?
  aiModel                String?
  aiApiKey               String?
  assistantInstructions  String?
  operationalInstructions String?
  hrInstructions         String?
  integrationNotes       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantDocument {
  id               String   @id @default(cuid())
  tenantId         String
  fileId           String
  uploadedByUserId String?
  accountId        String?
  channelEndpointId String?
  sourceType       String?
  sourceChannel    String?
  sourceProvider   String?
  externalEventId  String?
  area             String
  category         String
  title            String
  description      String?
  useForAi         Boolean  @default(false)
  extractedText    String?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  file             StoredFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy       User?    @relation(fields: [uploadedByUserId], references: [id])
  account          CommercialAccount? @relation(fields: [accountId], references: [id])
  channelEndpoint  ChannelEndpoint? @relation(fields: [channelEndpointId], references: [id])

  @@index([tenantId, area, category])
  @@index([tenantId, createdAt])
  @@index([tenantId, accountId, createdAt])
}

model TenantAlertTarget {
  id           String   @id @default(cuid())
  tenantId     String
  incidentType String?
  severityMin  Severity
  channel      NotificationChannel
  targetValue  String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, severityMin])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metaJson    Json?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, createdAt])
}

model Reminder {
  id             String         @id @default(cuid())
  tenantId       String
  userId         String
  createdByUserId String
  type           ReminderType
  title          String
  dueAt          DateTime
  status         ReminderStatus @default(pending)
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, status, dueAt])
  @@index([tenantId, status, dueAt])
}

model IntegrationApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  keyHash     String   @unique
  scopes      String[]
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  requests    IntegrationRequest[]

  @@index([tenantId, isActive])
  @@unique([tenantId, name])
}

model IntegrationRequest {
  id                  String   @id @default(cuid())
  tenantId            String
  integrationApiKeyId String
  operation           String
  idempotencyKey      String
  requestHash         String
  responseJson        Json?
  createdAt           DateTime @default(now())
  completedAt         DateTime?
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  integrationApiKey   IntegrationApiKey @relation(fields: [integrationApiKeyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, operation, idempotencyKey])
  @@index([tenantId, createdAt])
}

model WorkItem {
  id                String         @id @default(cuid())
  tenantId          String
  workType          WorkType
  status            WorkItemStatus @default(draft)
  title             String
  summary           String?
  accountId         String?
  contactPersonId   String?
  assignedUserId    String?
  createdByUserId   String
  targetAt          DateTime?
  metadataJson      Json?
  deliveryChannel   String?
  deliveryProvider  String?
  deliveryMessage   String?
  deliveryPayloadJson Json?
  deliveryEnabled   Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account           CommercialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactPerson     ContactPerson? @relation(fields: [contactPersonId], references: [id], onDelete: SetNull)
  assignedUser      User?          @relation("AssignedWorkItems", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy         User           @relation("CreatedWorkItems", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignments       WorkAssignment[]
  notes             OperationalNote[]
  events            WorkItemEvent[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, workType, createdAt])
  @@index([tenantId, assignedUserId, status])
  @@index([tenantId, accountId, createdAt])
}

model WorkAssignment {
  id               String               @id @default(cuid())
  tenantId         String
  workItemId       String
  assignedUserId   String
  assignedByUserId String
  status           WorkAssignmentStatus @default(active)
  assignedAt       DateTime             @default(now())
  acknowledgedAt   DateTime?
  endedAt          DateTime?
  metadataJson     Json?
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workItem         WorkItem             @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  assignedUser     User                 @relation("AssignedUserAssignments", fields: [assignedUserId], references: [id], onDelete: Restrict)
  assignedBy       User                 @relation("AssignmentActor", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, workItemId, assignedAt])
  @@index([tenantId, assignedUserId, status])
}

model OperationalNote {
  id               String              @id @default(cuid())
  tenantId         String
  type             OperationalNoteType
  title            String?
  content          String
  summary          String?
  workItemId       String?
  accountId        String?
  contactPersonId  String?
  createdByUserId  String?
  decidedByUserId  String?
  sourceMessageId  String?
  proposedByAi     Boolean             @default(false)
  confidence       Float?
  metadataJson     Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workItem         WorkItem?           @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  account          CommercialAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactPerson    ContactPerson?      @relation(fields: [contactPersonId], references: [id], onDelete: SetNull)
  createdBy        User?               @relation("OperationalNoteAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  decidedBy        User?               @relation("OperationalNoteDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  sourceMessage    ConversationMessage? @relation("OperationalNoteSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, createdAt])
  @@index([tenantId, workItemId, createdAt])
  @@index([tenantId, accountId, createdAt])
  @@index([tenantId, contactPersonId, createdAt])
}

model WorkItemEvent {
  id             String            @id @default(cuid())
  tenantId       String
  workItemId     String
  actorUserId    String?
  eventType      WorkItemEventType
  details        String?
  metaJson       Json?
  createdAt      DateTime          @default(now())
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workItem       WorkItem          @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  actor          User?             @relation("WorkItemEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, workItemId, createdAt])
  @@index([tenantId, eventType, createdAt])
}
